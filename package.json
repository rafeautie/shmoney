{
  "name": "shmoney",
  "version": "0.2.1",
  "description": "Local-first personal finance desktop app: accounts, budgets, reports, and on-device AI categorization",
  "main": "./out/main/index.js",
  "author": "Rafe Autie <devrafe@gmail.com>",
  "license": "PolyForm-Noncommercial-1.0.0",
  "homepage": "https://github.com/rafeautie/shmoney",
  "repository": {
    "type": "git",
    "url": "https://github.com/rafeautie/shmoney.git"
  },
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "predev": "npm run licenses:generate",
    "start": "electron-vite preview",
    "build": "electron-vite build",
    "prebuild": "npm run licenses:generate",
    "build:unpack": "npm run build && electron-builder --dir",
    "release:patch": "npm version patch && git push --follow-tags",
    "release:minor": "npm version minor && git push --follow-tags",
    "release:major": "npm version major && git push --follow-tags",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux",
    "licenses:generate": "license-checker-rseidelsohn --production --excludePrivatePackages --json --customPath scripts/license-fields.json --out src/renderer/src/generated/licenses.json",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run",
    "format": "prettier --write .",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@electron-toolkit/utils": "^4.0.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@hugeicons/core-free-icons": "^4.2.2",
    "@hugeicons/react": "^1.1.9",
    "@react-three/fiber": "^9.6.1",
    "@shadcn/react": "^0.2.1",
    "@shadergradient/react": "^2.4.20",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-router": "^1.170.18",
    "@tanstack/react-table": "^8.21.3",
    "better-sqlite3": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "currency-codes": "^2.2.0",
    "date-fns": "^4.4.0",
    "drizzle-orm": "^0.45.2",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.9",
    "node-llama-cpp": "^3.19.0",
    "ofx-js": "^1.1.1",
    "papaparse": "^5.5.4",
    "qif-ts": "^1.0.0",
    "react": "^19.2.7",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.7",
    "react-grid-layout": "^2.2.3",
    "recharts": "^3.10.0",
    "shadcn": "^4.12.0",
    "sonner": "^2.0.7",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.6.0",
    "three": "^0.185.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@tailwindcss/postcss": "^4.3.2",
    "@tanstack/react-query-devtools": "^5.101.2",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/router-plugin": "^1.168.20",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.1.1",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.3",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "drizzle-kit": "^0.31.10",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "license-checker-rseidelsohn": "^5.0.1",
    "prettier": "^3.9.4",
    "tailwindcss": "^4.3.3",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "^7.3.6",
    "vitest": "^4.1.9"
  },
  "allowScripts": {
    "node-llama-cpp@3.19.0": true
  }
}
